generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  password     String
  role         String    @default("user") // admin, user
  quota        BigInt    @default(1073741824) // 1GB default
  usedStorage  BigInt    @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tokens       Token[]
  files        File[]
}

model Token {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  token       String    @unique
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime  @default(now())
}

model File {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId    Int?
  parent      File?     @relation("FileToFile", fields: [parentId], references: [id], onDelete: Cascade)
  children    File[]    @relation("FileToFile")
  name        String
  path        String
  type        String    @default("file") // file, folder
  size        BigInt    @default(0)
  mimeType    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
